# Database — Railway provides this automatically when you add a Postgres plugin
DATABASE_URL="postgresql://user:password@host:5432/topicshare?schema=public"

# Auth — generate with: openssl rand -base64 32
JWT_SECRET="change-this-to-a-long-random-secret"

# App URL — Railway deployment URL (used for magic link emails)
# e.g. https://topicshare.up.railway.app (for testing) or https://your-domain.vercel.app (for production)
NEXT_PUBLIC_APP_URL="https://your-app.up.railway.app"

# Resend — get your API key from resend.com
RESEND_API_KEY="re_..."

# Cloudinary — get from cloudinary.com dashboard
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Qwen AI (Alibaba DashScope) — get from dashscope.aliyun.com
DASHSCOPE_API_KEY="sk-..."
QWEN_MODEL="qwen-max"
# DASHSCOPE_BASE_URL="https://dashscope-intl.aliyuncs.com/compatible-mode/v1"
